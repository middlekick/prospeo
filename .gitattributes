# Normalisation : tout en LF, fichiers source traités comme texte UTF-8.
# Empêche la réintroduction d'octets cp1252 (carrés blancs).
* text=auto eol=lf

*.tsx  text eol=lf
*.ts   text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.svg  text eol=lf

*.png  binary
*.ico  binary
*.woff2 binary
*.woff  binary
